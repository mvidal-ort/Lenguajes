module SkelCPP where

-- Haskell module generated by the BNF converter

import AbsCPP
import ErrM
type Result = Err String

failure :: Show a => a -> Result
failure x = Bad $ "Undefined case: " ++ show x

transId :: Id -> Result
transId x = case x of
  Id string -> failure x
transProgram :: Program -> Result
transProgram x = case x of
  PDefs defs -> failure x
transDef :: Def -> Result
transDef x = case x of
  DUsing idqs -> failure x
  DFun type_ id args stms -> failure x
  DFunInline type_ id args stms -> failure x
transArg :: Arg -> Result
transArg x = case x of
  ADecl type_ id -> failure x
  ADecl2 type_ ids -> failure x
  ADecl3 type_ ids -> failure x
  ADecl4 type_ id -> failure x
  ADecl5 type_ id -> failure x
  ADecl6 id ids -> failure x
  ADecl7 type_ restarg -> failure x
transRestArg :: RestArg -> Result
transRestArg x = case x of
  RestArg1 id -> failure x
  RestArg2 ids -> failure x
transStm :: Stm -> Result
transStm x = case x of
  SExp exp -> failure x
  SDecls type_ ids -> failure x
  SDeclsArray type_ ids exp -> failure x
  SInit type_ id exp -> failure x
  SConst type_ id -> failure x
  SConstPointer type_ id -> failure x
  SConstVector id type_ ids -> failure x
  SConstVectorPointer id type_ ids -> failure x
  SReturn exp -> failure x
  SReturnVoid -> failure x
  SWhile exp stm -> failure x
  SDo exp1 exp2 -> failure x
  SFor type_ id exp1 exp2 exp3 stm -> failure x
  SBlock stms -> failure x
  SIf exp stm restif -> failure x
  STypedef restotypedef -> failure x
  SStruct id reststruct -> failure x
transRestIf :: RestIf -> Result
transRestIf x = case x of
  SIfElse stm -> failure x
  SIFSimple -> failure x
transRestoTypedef :: RestoTypedef -> Result
transRestoTypedef x = case x of
  STypedef2 exp -> failure x
transRestStruct :: RestStruct -> Result
transRestStruct x = case x of
  SStructArg type_ id -> failure x
  SStructArgVector id type_ -> failure x
transExp :: Exp -> Result
transExp x = case x of
  ETrue -> failure x
  EFalse -> failure x
  EInt integer -> failure x
  EDouble double -> failure x
  EStrings strings -> failure x
  EChar char -> failure x
  EIndexing1 id exp -> failure x
  EIds idqs -> failure x
  EIndexing3 idqs id -> failure x
  EApp id exps -> failure x
  EPoint exp1 exp2 -> failure x
  EPointer exp1 exp2 -> failure x
  EPIncr exp -> failure x
  EPDecr exp -> failure x
  EExpo exp -> failure x
  EIncr exp -> failure x
  EDecr exp -> failure x
  EPot exp -> failure x
  ETimes exp1 exp2 -> failure x
  EDiv exp1 exp2 -> failure x
  EPorcent exp1 exp2 -> failure x
  EPlus exp1 exp2 -> failure x
  EMinus exp1 exp2 -> failure x
  ELeftShift exp1 exp2 -> failure x
  ERightShift exp1 exp2 -> failure x
  ELt exp1 exp2 -> failure x
  EGt exp1 exp2 -> failure x
  ELtEq exp1 exp2 -> failure x
  EGtEq exp1 exp2 -> failure x
  EEq exp1 exp2 -> failure x
  ENEq exp1 exp2 -> failure x
  EAnd exp1 exp2 -> failure x
  EOr exp1 exp2 -> failure x
  EAss exp1 exp2 -> failure x
  EPlusAss exp1 exp2 -> failure x
  EMinusAss exp1 exp2 -> failure x
  Econditional exp1 exp2 exp3 -> failure x
  ETrow exp -> failure x
  ETyped exp type_ -> failure x
transIdq :: Idq -> Result
transIdq x = case x of
  EVector vectortype restvector -> failure x
  Idq id -> failure x
transVectorType :: VectorType -> Result
transVectorType x = case x of
  VectorType1 type_ -> failure x
  VectorType2 id -> failure x
transRestVector :: RestVector -> Result
transRestVector x = case x of
  EVectorVar ids -> failure x
  EVectorNoVar -> failure x
transType :: Type -> Result
transType x = case x of
  Type_bool -> failure x
  Type_int -> failure x
  Type_double -> failure x
  Type_void -> failure x
  Type_char -> failure x

