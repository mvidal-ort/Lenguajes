-- Haskell data types for the abstract syntax.
-- Generated by the BNF converter.

module AbsCPP where

newtype Id = Id ((Int,Int),String)
  deriving (Eq, Ord, Show, Read)

data Program = PDefs [Def]
  deriving (Eq, Ord, Show, Read)

data Def
    = DUsing [Idq]
    | DFun Type Id [Arg] [Stm]
    | DFunInline Type Id [Arg] [Stm]
  deriving (Eq, Ord, Show, Read)

data Arg
    = ADecl Type Id
    | ADecl2 Type [Id]
    | ADecl3 Type [Id]
    | ADecl4 Type Id
    | ADecl5 Type Id
    | ADecl6 Id [Id]
    | ADecl7 Type RestArg
  deriving (Eq, Ord, Show, Read)

data RestArg = RestArg1 Id | RestArg2 [Id]
  deriving (Eq, Ord, Show, Read)

data Stm
    = SExp Exp
    | SDecls Type [Id]
    | SDeclsArray Type [Id] Exp
    | SInit Type Id Exp
    | SConst Type Id
    | SConstPointer Type Id
    | SConstVector Id Type [Id]
    | SConstVectorPointer Id Type [Id]
    | SReturn Exp
    | SReturnVoid
    | SWhile Exp Stm
    | SDo Exp Exp
    | SFor Type Id Exp Exp Exp Stm
    | SBlock [Stm]
    | SIf Exp Stm RestIf
    | STypedef RestoTypedef
    | SStruct Id RestStruct
  deriving (Eq, Ord, Show, Read)

data RestIf = SIfElse Stm | SIFSimple
  deriving (Eq, Ord, Show, Read)

data RestoTypedef = STypedef2 Exp
  deriving (Eq, Ord, Show, Read)

data RestStruct = SStructArg Type Id | SStructArgVector Id Type
  deriving (Eq, Ord, Show, Read)

data Exp
    = ETrue
    | EFalse
    | EInt Integer
    | EDouble Double
    | EStrings [String]
    | EChar Char
    | EIndexing1 Id Exp
    | EIds [Idq]
    | EIndexing3 [Idq] Id
    | EApp Id [Exp]
    | EPoint Exp Exp
    | EPointer Exp Exp
    | EPIncr Exp
    | EPDecr Exp
    | EExpo Exp
    | EIncr Exp
    | EDecr Exp
    | EPot Exp
    | ETimes Exp Exp
    | EDiv Exp Exp
    | EPorcent Exp Exp
    | EPlus Exp Exp
    | EMinus Exp Exp
    | ELeftShift Exp Exp
    | ERightShift Exp Exp
    | ELt Exp Exp
    | EGt Exp Exp
    | ELtEq Exp Exp
    | EGtEq Exp Exp
    | EEq Exp Exp
    | ENEq Exp Exp
    | EAnd Exp Exp
    | EOr Exp Exp
    | EAss Exp Exp
    | EPlusAss Exp Exp
    | EMinusAss Exp Exp
    | Econditional Exp Exp Exp
    | ETrow Exp
    | ETyped Exp Type
  deriving (Eq, Ord, Show, Read)

data Idq = EVector VectorType RestVector | Idq Id
  deriving (Eq, Ord, Show, Read)

data VectorType = VectorType1 Type | VectorType2 Id
  deriving (Eq, Ord, Show, Read)

data RestVector = EVectorVar [Id] | EVectorNoVar
  deriving (Eq, Ord, Show, Read)

data Type
    = Type_bool | Type_int | Type_double | Type_void | Type_char
  deriving (Eq, Ord, Show, Read)

