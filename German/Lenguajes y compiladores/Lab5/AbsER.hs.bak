-- Haskell data types for the abstract syntax.
-- Generated by the BNF converter.

module AbsER where

newtype AlfaName = AlfaName String
  deriving (Eq, Ord, Show, Read)

newtype ExpName = ExpName String
  deriving (Eq, Ord, Show, Read)

newtype Symbol = Symbol String
  deriving (Eq, Ord, Show, Read)

data Prog = Prog [Alfabeto] [ExpReg]
  deriving (Eq, Ord, Show, Read)

data Alfabeto = Alfabeto AlfaName [Symbol]
  deriving (Eq, Ord, Show, Read)

data ExpReg = ExpReg ExpName Exp AlfaName
  deriving (Eq, Ord, Show, Read)

data Exp
    = Evacio
    | EPalabraVacia
    | Esymbol Symbol
    | EConcat Exp Exp
    | EUnion Exp Exp
    | EIter Exp
  deriving (Eq, Ord, Show, Read)

