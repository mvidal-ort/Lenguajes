module SkelER where

-- Haskell module generated by the BNF converter

import AbsER
import ErrM
type Result = Err String

failure :: Show a => a -> Result
failure x = Bad $ "Undefined case: " ++ show x

transAlfaName :: AlfaName -> Result
transAlfaName x = case x of
  AlfaName string -> failure x
transExpName :: ExpName -> Result
transExpName x = case x of
  ExpName string -> failure x
transSymbol :: Symbol -> Result
transSymbol x = case x of
  Symbol string -> failure x
transProg :: Prog -> Result
transProg x = case x of
  Prog alfabetos expregs -> failure x
transAlfabeto :: Alfabeto -> Result
transAlfabeto x = case x of
  Alfabeto alfaname symbols -> failure x
transExpReg :: ExpReg -> Result
transExpReg x = case x of
  ExpReg expname exp alfaname -> failure x
transExp :: Exp -> Result
transExp x = case x of
  Evacio -> failure x
  EPalabraVacia -> failure x
  Esymbol symbol -> failure x
  EConcat exp1 exp2 -> failure x
  EUnion exp1 exp2 -> failure x
  EIter exp -> failure x

