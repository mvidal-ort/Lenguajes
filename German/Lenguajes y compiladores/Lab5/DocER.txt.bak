  | //[Symbol]// | -> | //Symbol//
  |  |  **|**  | //Symbol// ``,`` //[Symbol]//
  | //ExpReg// | -> | //ExpName// ``=`` //Exp// ``:`` //AlfaName//
  | //Exp4// | -> | ``{}``
  |  |  **|**  | ``eps``
